{
  "name": "vyapar-pakistan",
  "version": "0.1.0",
  "private": true,
  "description": "Vyapar Pakistan - Business management platform (Desktop + Mobile + Backend)",
  "scripts": {
    "dev:desktop": "pnpm --filter @vyapar/desktop dev",
    "dev:web": "pnpm --filter @vyapar/web dev",
    "dev:mobile": "pnpm --filter @vyapar/mobile start",
    "dev:backend": "pnpm --filter @vyapar/backend start:dev",
    "dev:all": "concurrently \"pnpm dev:backend\" \"pnpm dev:desktop\" \"pnpm dev:web\"",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
