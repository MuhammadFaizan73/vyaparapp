{
  "name": "@vyapar/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@vyapar/api-client": "workspace:*",
    "@vyapar/shared-types": "workspace:*",
    "@vyapar/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "pk.vyapar.desktop",
    "productName": "Vyapar Pakistan",
    "files": ["dist/**/*", "dist-electron/**/*"],
    "mac": { "category": "public.app-category.business" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  }
}
